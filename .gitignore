# Quarto
/.quarto/
/_site/
/_freeze/
*_files/
*_cache/
**/*.quarto_ipynb
# Stray render output that lands next to .qmd sources (e.g., from editor
# extensions that ignore `output-dir: _site`). Canonical builds live in
# /_site/; these siblings are always garbage.
/index.html
/404.html
/book/*.html
/media/*.html
/news/*.html
/posts/*.html
/working-papers/*.html

# Local-only design scratch (see auto-memory project_bird_tweak.md)
/_dev/

# OS / editors
.DS_Store
Thumbs.db
.Rproj.user
.Rhistory
.RData
.Ruserdata
.vscode/
