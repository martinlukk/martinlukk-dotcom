<%
function groupOf(item) {
  var cats = item.categories || [];
  if (!Array.isArray(cats)) cats = [cats];
  if (cats.indexOf('publication') !== -1) return 'publications';
  if (cats.indexOf('talk') !== -1) return 'presentations';
  if (cats.indexOf('media') !== -1 || cats.indexOf('writing') !== -1) return 'media';
  return 'other';
}

var visible = items.filter(function(item) { return !item.hide_in_news; });

var byYear = {};
var years = [];
visible.forEach(function(item) {
  var y = item.date ? new Date(item.date).getFullYear() : 'undated';
  if (!byYear[y]) { byYear[y] = []; years.push(y); }
  byYear[y].push(item);
});
%>
<div class="news-list">
<% years.forEach(function(year) { %>
<div class="news-year-group">
<div class="news-year"><%= year %></div>
<% byYear[year].forEach(function(item) { %>
<div class="news-item" data-group="<%= groupOf(item) %>">
<div class="news-date"><% if (item.date) { %><%= new Date(item.date).toLocaleDateString('en-US', {year: 'numeric', month: 'short'}) %><% } %></div>
<div class="news-text"><% var t = item.news_title || item.title; var href = item.book || item.path; if (href) { %><a href="<%= href %>"><%- t %></a><% } else { %><%- t %><% } %></div>
</div>
<% }); %>
</div>
<% }); %>
</div>
