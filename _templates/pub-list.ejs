<%
function hasCategory(item, name) {
  var cats = item.categories || [];
  if (!Array.isArray(cats)) cats = [cats];
  return cats.indexOf(name) !== -1;
}
function isPub(item) { return hasCategory(item, 'publication'); }
function isWP(item)  { return hasCategory(item, 'working-paper'); }

function yearOf(item) {
  if (item.year) return item.year;
  if (item.date) return new Date(item.date).getFullYear();
  return 'undated';
}

function titleOf(item) {
  return item.title;
}

function bestTitleHref(item) {
  if (item.book) return item.book;
  if (item.path) return item.path;
  if (item.project_page) return item.project_page;
  if (item.doi) return 'https://doi.org/' + item.doi;
  if (item.arxiv) return item.arxiv;
  return '';
}

// KEEP-IN-SYNC with `_filters/pub-detail.lua`: DOI_PUBLISHERS,
// URL_PLATFORMS, SKIP_WORDS, citeKey, and bibtexEntry are all
// duplicated in the Lua filter that renders pub detail pages. Edit
// both when adding a publisher, platform, or stop-word, or when
// changing cite-key / BibTeX rules. The chip vocabulary (PDF /
// Article / Preprint / Code & Data / Data / Materials / Preregistration /
// Supplement / Slides / Publisher / Excerpt / Buy / Preview /
// Project / Copy BibTeX) renders in the same order in both places
// with the same tooltip behavior (publisher for Article, platform
// for everything else). The `code` field drives the combined
// "Code & Data" chip; `data` is reserved for the rare standalone
// dataset release.
var DOI_PUBLISHERS = {
  '10.1002': 'Wiley',
  '10.1177': 'Sage',
  '10.1086': 'U Chicago',
  '10.1093': 'Oxford',
  '10.1007': 'Springer',
  '10.1080': 'Taylor & Francis',
  '10.1146': 'Annual Reviews',
  '10.1126': 'Science',
  '10.1038': 'Nature',
  '10.1145': 'ACM',
  '10.1109': 'IEEE',
  '10.1257': 'AEA',
};

var URL_PLATFORMS = [
  { re: /github\./i,        label: 'GitHub'        },
  { re: /gitlab\./i,        label: 'GitLab'        },
  { re: /bitbucket\./i,     label: 'Bitbucket'     },
  { re: /osf\.io/i,         label: 'OSF'           },
  { re: /zenodo\.org/i,     label: 'Zenodo'        },
  { re: /dataverse/i,       label: 'Dataverse'     },
  { re: /icpsr\.umich/i,    label: 'ICPSR'         },
  { re: /aspredicted/i,     label: 'AsPredicted'   },
  { re: /arxiv\.org/i,      label: 'arXiv'         },
  { re: /ssrn\.com/i,       label: 'SSRN'          },
  { re: /biorxiv\.org/i,    label: 'bioRxiv'       },
  { re: /medrxiv\.org/i,    label: 'medRxiv'       },
  { re: /psyarxiv/i,        label: 'PsyArXiv'      },
  { re: /researchgate/i,    label: 'ResearchGate'  },
  { re: /figshare/i,        label: 'Figshare'      },
  { re: /amazon\./i,        label: 'Amazon'        },
  { re: /google\.com\/books/i, label: 'Google Books' },
];

var SKIP_WORDS = {
  a: 1, an: 1, the: 1, on: 1, of: 1, in: 1, for: 1, to: 1,
  and: 1, or: 1, is: 1,
};

// KEEP-IN-SYNC with `_includes/pub-filter.html` and `assets/js/pub-self.js`.
// Project pill display labels — keys are the `pub_project` slug from
// frontmatter, values are the human-readable label shown on listings,
// detail pages, and filter buttons.
var PROJECT_LABELS = {
  'algorithmic-fairness':  'Algorithmic Fairness',
  'crowdfunding-welfare':  'Crowdfunding & Social Welfare',
  'political-conflict':    'Political Identity & Conflict',
};
function projectLabel(slug) {
  return (slug && PROJECT_LABELS[slug]) || slug || '';
}

function publisherLabel(doi) {
  if (!doi) return null;
  var m = String(doi).match(/^(10\.\d+)/);
  return (m && DOI_PUBLISHERS[m[1]]) || null;
}

function platformLabel(url) {
  if (!url) return null;
  for (var i = 0; i < URL_PLATFORMS.length; i++) {
    if (URL_PLATFORMS[i].re.test(url)) return URL_PLATFORMS[i].label;
  }
  return null;
}

function citeKey(item, authors, year) {
  if (item.cite_key) return String(item.cite_key);
  var first = String((authors && authors[0]) || '').trim();
  var family = first.split(/\s+/).pop().toLowerCase().replace(/[^a-z]/g, '');
  var y = String(year || '').replace(/[^\d]/g, '');
  var titleClean = String(item.title || '').replace(/\*/g, '').replace(/-/g, ' ');
  var word = '';
  var parts = titleClean.split(/\s+/);
  for (var i = 0; i < parts.length; i++) {
    var clean = parts[i].toLowerCase().replace(/[^a-z]/g, '');
    if (clean && !SKIP_WORDS[clean]) { word = clean; break; }
  }
  return family + y + word;
}

function bibtexEntry(item, authors, year, key) {
  var isBook = !!item.book;
  var isWp = isWP(item);
  var entry = isBook ? 'book' : (isWp ? 'unpublished' : 'article');
  var venue = String(item.venue || '');
  var doi = String(item.doi || '');
  var title = String(item.title || '').replace(/\*/g, '');

  var lines = [
    '@' + entry + '{' + key + ',',
    '  author = {' + authors.join(' and ') + '},',
    '  title = {' + title + '},',
  ];
  if (isBook) {
    if (venue) lines.push('  publisher = {' + venue + '},');
  } else if (isWp) {
    lines.push('  note = {' + (venue || 'Working paper') + '},');
  } else {
    if (venue) lines.push('  journal = {' + venue + '},');
  }
  if (year) lines.push('  year = {' + String(year) + '},');
  if (doi) lines.push('  doi = {' + doi + '},');
  lines[lines.length - 1] = lines[lines.length - 1].replace(/,$/, '');
  lines.push('}');
  return lines.join('\n');
}

function escapeHtml(s) {
  return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function escapeAttr(s) {
  return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;')
                  .replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

// Chip render helper — `Article` carries publisher+DOI in title;
// every other non-Project chip carries a platform name in title
// when the URL host is recognized.
function chipWithPlatform(label, href) {
  if (!href) return '';
  var plat = platformLabel(href);
  var titleAttr = plat ? (' title="' + escapeAttr(plat) + '"') : '';
  return '<a class="chip" href="' + escapeAttr(href) + '"' + titleAttr + '>' + label + '</a>';
}

// Render one <li>. Working papers share everything but the venue line:
// they have no journal/year of record, so the line falls back to a
// venue string (e.g. "Working paper" or "Under review at X") plus the
// project pill. Pubs render `<venue>, <year>` as before.
function renderItem(item) {
  var year = yearOf(item);
  var href = bestTitleHref(item);
  var authors = (item.authors || []).map(function(a){ return String(a).trim(); });
  var key = citeKey(item, authors, year);
  var bib = bibtexEntry(item, authors, year, key);
  var bibtexId = 'bibtex-' + key;
  var preprintHref = item.preprint || item.arxiv;

  var out = '';
  out += '<li data-projects="' + escapeAttr(item.pub_project || '') + '">';

  out += '<div class="pub-title">';
  if (href) {
    out += '<a href="' + escapeAttr(href) + '">' + escapeHtml(titleOf(item)) + '</a>';
  } else {
    out += escapeHtml(titleOf(item));
  }
  out += '</div>';

  out += '<div class="pub-authors">';
  authors.forEach(function(a, i) {
    if (i > 0) out += ', ';
    var isSelf = (a === 'Martin Lukk' || a === 'M. Lukk' || a === 'Lukk, M.');
    if (isSelf) {
      out += '<span class="pub-self">' + escapeHtml(a) + '</span>';
    } else {
      out += escapeHtml(a);
    }
  });
  out += '</div>';

  out += '<div class="pub-venue">';
  var venueText = item.venue || '';
  if (venueText) out += venueText;
  if (venueText && year) out += ', ';
  if (year) out += year;
  if (item.pub_project) {
    out += ' <span class="pub-tag pub-project-tag">' + projectLabel(item.pub_project) + '</span>';
  }
  out += '</div>';

  out += '<div class="chips">';
  out += chipWithPlatform('PDF', item.pdf);
  if (item.doi) {
    var pub = publisherLabel(item.doi);
    var title = pub ? (pub + ' · DOI: ' + item.doi) : ('DOI: ' + item.doi);
    out += '<a class="chip" href="https://doi.org/' + escapeAttr(item.doi) +
           '" title="' + escapeAttr(title) + '">Article</a>';
  }
  out += chipWithPlatform('Preprint',    preprintHref);
  out += chipWithPlatform('Code & Data', item.code);
  out += chipWithPlatform('Data',        item.data);
  out += chipWithPlatform('Materials',   item.materials);
  out += chipWithPlatform('Preregistration', item.prereg);
  out += chipWithPlatform('Supplement',  item.supplement);
  out += chipWithPlatform('Slides',      item.slides);
  // Book-specific chips: rendered when the entry has `book:` set.
  // Tooltip for "Publisher" uses item.venue (e.g., "Stanford University
  // Press"); the other three use URL_PLATFORMS via chipWithPlatform.
  if (item.publisher_url) {
    var pubLabel = item.venue || platformLabel(item.publisher_url);
    var pubTitle = pubLabel ? (' title="' + escapeAttr(pubLabel) + '"') : '';
    out += '<a class="chip" href="' + escapeAttr(item.publisher_url) + '"' + pubTitle + '>Publisher</a>';
  }
  out += chipWithPlatform('Excerpt', item.excerpt_url);
  out += chipWithPlatform('Buy',     item.buy_url);
  out += chipWithPlatform('Preview', item.preview_url);
  if (item.project_page) {
    out += '<a class="chip" href="' + escapeAttr(item.project_page) + '">Project</a>';
  }
  if (!item.no_bibtex) {
    out += '<button type="button" class="chip pub-cite" aria-label="Copy BibTeX citation to clipboard" data-cite-target="' + bibtexId + '">Copy BibTeX</button>';
  }
  out += '</div>';

  if (!item.no_bibtex) {
    out += '<script type="application/x-bibtex" id="' + bibtexId + '">' +
           bib.replace(/<\/script>/g, '<\\/script>') +
           '</script>';
  }
  out += '</li>';
  return out;
}

var wps  = items.filter(isWP);
var pubs = items.filter(isPub);
const byYear = {};
pubs.forEach(function(item) {
  var y = yearOf(item);
  (byYear[y] = byYear[y] || []).push(item);
});
var years = Object.keys(byYear).sort(function(a,b){ return (b|0) - (a|0); });
%>
<% if (wps.length) { %>
<h2 class="pub-year wp-heading">Working Papers</h2>
<ul class="pub-list">
<% wps.forEach(function(item) { %><%= renderItem(item) %><% }); %>
</ul>
<% } %>
<% years.forEach(function(year) { %>
<h2 class="pub-year"><%= year %></h2>
<ul class="pub-list">
<% byYear[year].forEach(function(item) { %><%= renderItem(item) %><% }); %>
</ul>
<% }); %>
